CONFIG_ESPTOOLPY_FLASHSIZE_4MB=y
CONFIG_ESPTOOLPY_FLASHSIZE="4MB"

# Usb Serial
CONFIG_ESP_CONSOLE_USB_CDC=y
CONFIG_ESP32S2_KEEP_USB_ALIVE=y

# Custom partition table needed for embedded TTF font
CONFIG_PARTITION_TABLE_CUSTOM=y
CONFIG_PARTITION_TABLE_CUSTOM_FILENAME="partitions.csv"

# Use system malloc (ESP-IDF heap) instead of LVGL's 64 KB static DRAM pool
CONFIG_LV_USE_BUILTIN_MALLOC=n
CONFIG_LV_USE_CLIB_MALLOC=y

# Don't compile LVGL example files (they contain large static canvas buffers)
CONFIG_LV_BUILD_EXAMPLES=n

# Bump FreeRTOS tick to 1 ms so esp_lvgl_port 5 ms timer is accurate
CONFIG_FREERTOS_HZ=1000


# Color logs 
CONFIG_BOOTLOADER_LOG_COLORS=y